{
  "name": "n8n-nodes-reflect-memory",
  "version": "1.0.0",
  "description": "n8n community node for Reflect Memory — read, write, browse, and search AI memories.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "reflect-memory",
    "memory",
    "ai",
    "mcp"
  ],
  "license": "MIT",
  "homepage": "https://reflectmemory.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/reflectmemory/n8n-nodes-reflect-memory"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "tslint -p tsconfig.json -c tslint.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ReflectMemoryApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ReflectMemory/ReflectMemory.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "gulp": "^5.0.0",
    "n8n-workflow": "*",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
