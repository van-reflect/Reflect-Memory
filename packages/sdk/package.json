{
  "name": "reflect-memory-sdk",
  "version": "0.2.0",
  "description": "TypeScript client SDK for the Reflect Memory API",
  "author": "Reflect Memory Inc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/van-reflect/reflect-memory.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "reflect",
    "memory",
    "ai",
    "ai-memory",
    "ai-agents",
    "agent",
    "sdk",
    "api-client",
    "mcp",
    "model-context-protocol",
    "llm",
    "chatgpt",
    "claude",
    "cursor",
    "developer-tools",
    "vendor-neutral"
  ]
}
